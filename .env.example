NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=
RESEND_API_KEY=
NEXT_PUBLIC_ORDER_FORM_URL=
# Shared secret for the Sanity -> /api/revalidate webhook (instant content updates).
# Set the same value here, in Vercel, and in the Sanity webhook config.
SANITY_REVALIDATE_SECRET=
# Optional — production site URL used for metadataBase / OG tags.
# Defaults to https://my-wifes-dumplings.vercel.app when unset.
NEXT_PUBLIC_SITE_URL=

# --- WP-8: .NET ordering/payments backend ---
# Base URL of the ASP.NET Core API (no trailing slash), e.g.
#   https://mywifesdumplings-api.azurewebsites.net
# Local dev typically http://localhost:5000 (whatever the API listens on).
NEXT_PUBLIC_API_BASE_URL=
# Stripe PUBLISHABLE key (pk_test_... / pk_live_...). This is NOT secret and is
# safe in the browser, but it still belongs in env so test/live keys swap per
# environment. NEVER put a Stripe SECRET key (sk_...) in this repo — secret keys
# live only in the backend / Azure Key Vault.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
